---
import { Image } from 'astro:assets';
import Sheet from '../layouts/Sheet.astro';
import { sheets } from '../data/sheets';
import heroImage from '../assets/arthur-hero.jpg';

const name = "Arthur Nguyen";
const tagline = "Bringing AI tools to traditional manufacturing.";
const role = "VP of Projects & Operations, Volume Millwork";
const email = "ArthurOnSite@outlook.com";
const projectNumber = "AN-001";
const issueDate = new Date()
  .toLocaleDateString("en-US", { year: "numeric", month: "short", day: "2-digit" })
  .toUpperCase();

const channels = [
  {
    code: "FB",
    name: "Facebook",
    handle: "arthur.win.nguyen",
    href: "https://m.me/arthur.win.nguyen",
  },
  {
    code: "IG",
    name: "Instagram",
    handle: "@art.win.nguyen",
    href: "https://ig.me/m/art.win.nguyen",
  },
  {
    code: "LI",
    name: "LinkedIn",
    handle: "arthur-liem-nguyen",
    href: "https://www.linkedin.com/in/arthur-liem-nguyen-25484b23",
  },
];
---

<Sheet>

  {/* ───────── SHEET T-01 — TITLE ───────── */}
  <section id="t-01" class="sheet min-h-screen flex flex-col py-10 md:py-12 reveal relative">

    <!-- North arrow, top right -->
    <svg class="north-arrow" viewBox="0 0 60 60" aria-hidden="true">
      <circle cx="30" cy="30" r="28" fill="none" stroke="#8a6a44" stroke-width="0.6"/>
      <path d="M30 6 L36 36 L30 30 L24 36 Z" fill="#2a2520"/>
      <path d="M30 30 L36 36 L30 54 L24 36 Z" fill="none" stroke="#2a2520" stroke-width="0.6"/>
      <text x="30" y="20" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#2a2520">N</text>
    </svg>

    <header class="bubble-row">
      <span class="bubble">{sheets[0].num}</span>
      <span class="bubble-line"></span>
      <span class="bubble-label">{sheets[0].title.toUpperCase()}</span>
      <span class="rev-triangle" title="Revision 1">
        <svg viewBox="0 0 16 16"><polygon points="8,1 15,14 1,14" fill="none" stroke="#8a6a44" stroke-width="1"/><text x="8" y="13" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#8a6a44">1</text></svg>
      </span>
    </header>

    <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center flex-1 py-10 md:py-16">
      <div class="relative">
        <span class="margin-note">Houston, TX</span>
        <h1 class="font-serif text-4xl sm:text-5xl md:text-7xl tracking-tight leading-none mb-6">
          {name}
        </h1>
        <p class="text-lg md:text-xl text-ink/85 max-w-lg leading-relaxed mb-6">
          {tagline}
        </p>
        <p class="text-xs uppercase tracking-[0.25em] text-muted">
          {role}
        </p>
      </div>

      <div class="dim-wrap" data-parallax-y="-0.12">
        <div class="frame">
          <Image
            src={heroImage}
            alt="Arthur Nguyen reviewing construction drawings on-site"
            widths={[400, 800, 1200]}
            sizes="(min-width: 768px) 50vw, 100vw"
            class="w-full h-auto object-cover aspect-[3/4]"
          />
        </div>
        <span class="dim dim-right"><span class="dim-label">24"</span></span>
        <span class="dim dim-bottom"><span class="dim-label">18"</span></span>
      </div>
    </div>

    <div class="title-block">
      <div class="tb-cell tb-wide">
        <div class="tb-key">Project</div>
        <div class="tb-val">Arthur Nguyen — Portfolio</div>
      </div>
      <div class="tb-cell">
        <div class="tb-key">Drawn</div>
        <div class="tb-val">A. NGUYEN</div>
      </div>
      <div class="tb-cell">
        <div class="tb-key">Date</div>
        <div class="tb-val">{issueDate}</div>
      </div>
      <div class="tb-cell">
        <div class="tb-key">Scale</div>
        <div class="tb-val">NTS</div>
      </div>
      <div class="tb-cell">
        <div class="tb-key">Proj No.</div>
        <div class="tb-val">{projectNumber}</div>
      </div>
      <div class="tb-cell tb-sheet">
        <div class="tb-key">Sheet</div>
        <div class="tb-val tb-sheet-num">{sheets[0].num}</div>
      </div>
    </div>

    <div class="scale-bar" aria-hidden="true">
      <div class="scale-graphic">
        <span></span><span></span><span></span><span></span>
      </div>
      <div class="scale-label">0&nbsp;&nbsp;&nbsp;1'&nbsp;&nbsp;&nbsp;2'&nbsp;&nbsp;&nbsp;3'&nbsp;&nbsp;&nbsp;4'</div>
    </div>
  </section>

  <div class="match-line" aria-hidden="true">
    <span class="match-tag">MATCH LINE — SEE SHEET {sheets[1].num}</span>
  </div>

  {/* ───────── SHEET A-01 — ABOUT ───────── */}
  <section id="a-01" class="sheet py-16 md:py-24 reveal relative">
    <header class="bubble-row">
      <span class="bubble">{sheets[1].num}</span>
      <span class="bubble-line"></span>
      <span class="bubble-label">{sheets[1].title.toUpperCase()}</span>
    </header>

    <div class="grid md:grid-cols-12 gap-8 mt-12">
      <aside class="md:col-span-3">
        <div class="dim-label-block">
          <span class="dim-tick"></span>
          <span class="dim-text">— Background</span>
          <span class="dim-tick"></span>
        </div>
        <p class="hand-note">
          Architectural millwork. Construction.
          Manufacturing. Project management.
          Sales. Operational growth.
        </p>
      </aside>

      <div class="md:col-span-9 max-w-2xl space-y-6 text-base md:text-lg leading-[1.85] text-ink/85">
        <p>
          VP of Projects & Operations with a strong background in
          architectural millwork, construction, manufacturing, project
          management, sales, and operational growth. Currently serving at
          Volume Millwork, where I focus on improving processes, supporting
          teams, strengthening client relationships, and helping scale the
          business with purpose, structure, and consistency.
        </p>
        <p>
          I'm passionate about construction, craftsmanship, and building
          strong relationships with people who care about doing quality
          work. I enjoy connecting with owners, builders, designers,
          vendors, and industry professionals who share that same drive.
          All you have to do is ask; I will help you.
        </p>
      </div>
    </div>
  </section>

  <div class="match-line" aria-hidden="true">
    <span class="match-tag">MATCH LINE — SEE SHEET {sheets[2].num}</span>
  </div>

  {/* ───────── SHEET C-01 — CONTACT ───────── */}
  <section id="c-01" class="sheet py-16 md:py-24 reveal relative">
    <header class="bubble-row">
      <span class="bubble">{sheets[2].num}</span>
      <span class="bubble-line"></span>
      <span class="bubble-label">{sheets[2].title.toUpperCase()}</span>
    </header>

    <div class="mt-16 max-w-2xl">
      <div class="dim-label-block mb-6">
        <span class="dim-tick"></span>
        <span class="dim-text">— Direct line</span>
        <span class="dim-tick"></span>
      </div>

      <div class="rev-wrap">
        <a
          href={`mailto:${email}`}
          class="inline-block font-serif text-xl sm:text-2xl md:text-5xl text-ink hover:text-oakDark transition-colors duration-300 border-b border-oak/40 hover:border-oakDark pb-2 break-all"
        >
          {email}
        </a>
        <span class="rev-cloud-num">1</span>
      </div>

      <div class="mt-14">
        <div class="dim-label-block mb-5">
          <span class="dim-tick"></span>
          <span class="dim-text">— Message directly</span>
          <span class="dim-tick"></span>
        </div>
        <ul class="channel-list">
          {channels.map((c) => (
            <li>
              <a class="channel-row" href={c.href} target="_blank" rel="noopener noreferrer">
                <span class="ch-bubble">{c.code}</span>
                <span class="ch-line"></span>
                <span class="ch-meta">
                  <span class="ch-name">{c.name}</span>
                  <span class="ch-handle">{c.handle}</span>
                </span>
                <span class="ch-arrow" aria-hidden="true">↗</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <p class="mt-12 font-serif italic text-base text-ink/70 max-w-md">
        "All you have to do is ask; I will help you."
      </p>
    </div>

    <div class="end-of-set">
      <div class="eos-rule"></div>
      <span>END OF SET</span>
      <div class="eos-rule"></div>
    </div>

    <p class="copy-line">
      © {new Date().getFullYear()} {name} &nbsp;·&nbsp; {projectNumber}
    </p>
  </section>

</Sheet>
